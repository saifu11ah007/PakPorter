{
  "version": 2,
  "builds": [
    {
      "src": "api/express.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "node_modules/tesseract.js-core/**",
          "node_modules/tesseract.js/**",
          "eng.traineddata"
        ],
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/express.js"
    }
  ]
}